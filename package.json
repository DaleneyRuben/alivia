{
  "name": "alivia",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:seed": "tsx prisma/seed.ts",
    "postinstall": "prisma generate",
    "prepare": "husky"
